{
  "name": "automattic/vip-go-skeleton",
  "description": "Used for setting up development dependencies across the whole repository.",
  "homepage": "https://github.com/automattic/vip-go-skeleton",
  "license": "GPL-2.0-or-later",
  "require": {
    "php": ">=8.2",
		"wpackagist-theme/twentytwentyfive":"1.3",
    "wpackagist-plugin/cookiebot":"4.6.0",
    "wpackagist-plugin/duplicate-post":"4.5",
    "wpackagist-plugin/find-my-blocks":"4.0.3",
		"wpackagist-plugin/icon-block":"2.0.0",
		"wpackagist-plugin/redirection":"5.5.2",
    "wpackagist-plugin/the-events-calendar":"6.15.11",
    "wpackagist-plugin/weather-atlas":"3.0.4",
		"wpackagist-plugin/wordpress-seo":"26.3",
    "10up/classifai": "3.7.0"
  },
  "require-dev": {
    "automattic/vipwpcs": "^3",
    "phpcompatibility/phpcompatibility-wp": "^2"
  },
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true,
			"composer/installers": true
    }
  },
	"repositories": [
		{
			"type": "composer",
			"url": "https://wpackagist.org"
		},
    {
      "type": "package",
      "package": {
          "name": "10up/classifai",
          "version": "3.7.0",
          "type": "wordpress-plugin",
          "dist": {
              "url": "https://github.com/10up/classifai/archive/refs/tags/3.7.0.zip",
              "type": "zip"
          }
      }
    }
	],
	"extra": {
		"installer-paths": {
			"plugins/{$name}/": [ "type:wordpress-plugin" ],
			"themes/{$name}/": [ "type:wordpress-theme" ]
		}
	}
}
