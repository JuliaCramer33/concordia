{
  "name": "kanahoma/responsive-settings",
  "description": "Kanahoma Responsive Settings for Gutenberg",
  "type": "project",
  "license": "GPL-3.0",
  "autoload": {
    "classmap": [
      "includes/"
    ]
  },
  "authors": [
    {
      "name": "Daniel Post",
      "email": "daniel@posty.studio"
    }
  ],
  "require-dev": {
    "dealerdirect/phpcodesniffer-composer-installer": "^1.0",
