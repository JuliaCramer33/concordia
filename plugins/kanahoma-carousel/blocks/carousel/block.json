{
  "apiVersion": 3,
  "name": "kanahoma/carousel",
  "title": "Kanahoma Carousel",
  "category": "layout",
  "icon": "images-alt2",
  "description": "A flexible Kanahoma carousel block with arrows, progress, and optional title.",
  "supports": {
    "align": [
      "wide",
      "full"
    ],
    "anchor": true,
    "spacing": {
      "margin": true,
      "padding": true
    },
    "color": {
      "background": true,
      "text": false
    }
  },
  "attributes": {
    "spvMobile": {
      "type": "number",
      "default": 1
    },
    "spvTablet": {
      "type": "number",
      "default": 2
    },
    "spvDesktop": {
      "type": "number",
      "default": 4
    },
    "gap": {
      "type": "string",
      "default": "1rem"
    },
    "peek": {
      "type": "string",
      "default": "0px"
    },
    "arrows": {
      "type": "string",
      "default": "top-right"
    },
    "showProgress": {
      "type": "boolean",
      "default": true
    },
    "titleText": {
      "type": "string",
      "default": ""
    },
    "titleLevel": {
      "type": "string",
      "default": "h3"
    },
    "titleColor": {
      "type": "string",
      "default": ""
    },
    "titleAlign": {
      "type": "string",
      "default": "left"
    },
    "titleFontSize": {
      "type": "string",
      "default": ""
    },
    "mode": {
      "type": "string",
      "default": "auto"
    },
    "bleed": {
      "type": "string",
      "default": "none"
    }
  },
  "editorScript": "file:./edit.js",
  "viewScript": "file:./view.js",
  "style": "file:./style.css",
  "editorStyle": "file:./editor.css",
  "render": "file:./render.php"
}
